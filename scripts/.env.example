# 飞书开放平台应用凭据
# 获取方式: https://open.feishu.cn/app → 创建企业自建应用 → 凭证与基础信息
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 飞书多维表格配置
# 获取方式: 打开多维表格 → URL 中 /base/ 后的字符串即 app_token
# table_id: 点击表格 → URL 中 table= 后的字符串
FEISHU_BITABLE_APP_TOKEN=bascnxxxxxxxxxxxxxxxx
FEISHU_BITABLE_TABLE_ID=tblxxxxxxxxxxxxxxxx

# 飞书文件夹 token（存放生成的文档）
# 获取方式: 打开目标文件夹 → URL 中最后一段即 folder_token
FEISHU_FOLDER_TOKEN=fldcnxxxxxxxxxxxxxxxx

# GEO 文章专用文件夹 token（留空则与 FEISHU_FOLDER_TOKEN 合用一个文件夹）
FEISHU_GEO_FOLDER_TOKEN=

# 代理（可选，仅用于访问麦肯锡，飞书 API 不走代理）
# IP 被 Akamai 封禁时必须配。留空则直连。
# PROXY_URL=socks5://127.0.0.1:1080
# PROXY_URL=http://user:pass@proxy.example.com:8080

# ── 产品关联度阈值 ───────────────────────────────────────
# 抓到的文章与产品关键词的关联度分数 < 阈值则不入库、不生成 GEO。
# 范围 0-1，默认 0.2（≈ 命中 4 个产品关键词）。
RELEVANCE_THRESHOLD=0.2

# ── LLM 供应商选择 ───────────────────────────────────────
# GEO 文章生成走哪家：openai | qwen
# 两家都基于 OpenAI Chat Completions 协议，仅凭据 / base_url / model 不同。
# 切换后只有被选中那一组 *_API_KEY 等变量生效。
LLM_PROVIDER=openai

# ── OpenAI（GEO 文章生成） ───────────────────────────────
# 兼容 OpenAI 协议的 Chat Completions 接口；可切到中转/自建网关。
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
OPENAI_MODEL=gpt-5-codex
# OPENAI_MAX_TOKENS=4096
# OPENAI_TIMEOUT=120

# ── 通义千问（DashScope 兼容模式） ───────────────────────
# DashScope 提供 OpenAI 协议兼容端点，base_url 保持到 /compatible-mode 即可。
# API KEY 获取：https://dashscope.console.aliyun.com/apiKey
# 可用模型示例：qwen3-max / qwen-max / qwen-plus / qwen-turbo
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode
QWEN_MODEL=qwen3-max
# QWEN_MAX_TOKENS=4096
# QWEN_TIMEOUT=120

# ── 飞书 GEO 应用机器人通知 ──────────────────────────────
# 采用顶部 FEISHU_APP_ID / FEISHU_APP_SECRET 的应用机器人发消息，
# 通过 /open-apis/im/v1/messages 调用。
# 前置条件：
#   1. 应用开通 im:message:send_as_bot（"获取与发送单聊、群组消息"）scope
#   2. 机器人已被加入下方 receive_id 指向的群
# 留空则跳过通知（不抛错）。
#
# receive_id 取值：
#   - chat_id（群）：打开群 → 设置 → 群信息 → 复制 chat_id
#     或调用 /open-apis/im/v1/chats 查询机器人所在群
#   - open_id / user_id / union_id / email：看 receive_id_type
FEISHU_GEO_NOTIFY_RECEIVE_ID=
# 可选：chat_id（默认） | open_id | user_id | union_id | email
FEISHU_GEO_NOTIFY_RECEIVE_ID_TYPE=chat_id
