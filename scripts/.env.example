# 飞书开放平台应用凭据
# 获取方式: https://open.feishu.cn/app → 创建企业自建应用 → 凭证与基础信息
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 飞书多维表格配置
# 获取方式: 打开多维表格 → URL 中 /base/ 后的字符串即 app_token
# table_id: 点击表格 → URL 中 table= 后的字符串
FEISHU_BITABLE_APP_TOKEN=bascnxxxxxxxxxxxxxxxx
FEISHU_BITABLE_TABLE_ID=tblxxxxxxxxxxxxxxxx

# 飞书文件夹 token（存放生成的文档）
# 获取方式: 打开目标文件夹 → URL 中最后一段即 folder_token
FEISHU_FOLDER_TOKEN=fldcnxxxxxxxxxxxxxxxx

# GEO 文章专用文件夹 token（留空则与 FEISHU_FOLDER_TOKEN 合用一个文件夹）
FEISHU_GEO_FOLDER_TOKEN=

# 代理（可选，仅用于访问麦肯锡，飞书 API 不走代理）
# IP 被 Akamai 封禁时必须配。留空则直连。
# PROXY_URL=socks5://127.0.0.1:1080
# PROXY_URL=http://user:pass@proxy.example.com:8080

# ── 产品关联度阈值 ───────────────────────────────────────
# 抓到的文章与产品关键词的关联度分数 < 阈值则不入库、不生成 GEO。
# 范围 0-1，默认 0.2（≈ 命中 4 个产品关键词）。
RELEVANCE_THRESHOLD=0.2

# ── OpenAI（GEO 文章生成） ───────────────────────────────
# 兼容 OpenAI 协议的 Chat Completions 接口；可切到中转/自建网关。
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
OPENAI_MODEL=gpt-5-codex
# OPENAI_MAX_TOKENS=4096
# OPENAI_TIMEOUT=120

# ── 飞书 GEO 自定义机器人（生成新 GEO 文章后推送通知） ───
# 获取方式: 群设置 → 群机器人 → 添加自定义机器人 → 复制 Webhook 地址
LARK_GEO_BOT_WEBHOOK=
# 机器人勾选「签名校验」才需要填；未勾选留空即可。
LARK_GEO_BOT_SECRET=
